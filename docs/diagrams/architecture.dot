digraph Architecture {
    rankdir=TB;
    node [shape=box, style="rounded,filled", fontname="Helvetica"];
    edge [fontname="Helvetica"];
    
    // Ingestion subgraph
    subgraph cluster_ingestion {
        label="Data Ingestion";
        style=filled;
        color=lightgrey;
        
        P1 [label="ingest_fpl.py", fillcolor="#fff3cd"];
        P2 [label="ingest_vaastav.py", fillcolor="#fff3cd"];
        P3 [label="ingest_understat.py", fillcolor="#fff3cd"];
    }
    
    // Bronze layer
    subgraph cluster_bronze {
        label="Bronze Layer (Raw Data)";
        style=filled;
        color="#ffe5cc";
        
        B1 [label="bronze_fpl_players"];
        B2 [label="bronze_fpl_teams"];
        B3 [label="bronze_fpl_fixtures"];
        B4 [label="bronze_player_history"];
        B5 [label="bronze_understat_*"];
        B6 [label="bronze_team_mappings"];
    }
    
    // Silver layer
    subgraph cluster_silver {
        label="Silver Layer (Cleaned/Standardized)";
        style=filled;
        color="#d4edda";
        
        S1 [label="silver_players"];
        S2 [label="silver_teams"];
        S3 [label="silver_player_history"];
        S4 [label="silver_player_crosswalk"];
    }
    
    // Feature Engineering
    Features [label="Feature Engineering\n(Rolling, H2H, Form)", shape=box3d, fillcolor="#e2e3e5"];
    
    // Gold layer
    subgraph cluster_gold {
        label="Gold Layer (ML-Ready)";
        style=filled;
        color="#cce5ff";
        
        G1 [label="gold_player_features"];
    }
    
    // ML Models
    subgraph cluster_ml {
        label="ML Models";
        style=filled;
        color="#f8d7da";
        
        ML1 [label="LightGBM\nPoints Predictor"];
        ML2 [label="LightGBM\nXI Classifier"];
        ML3 [label="Monte Carlo\nSimulation"];
    }
    
    // Predictions
    G2 [label="gold_predictions", fillcolor="#cce5ff"];
    G3 [label="gold_user_teams", fillcolor="#cce5ff"];
    
    // Optimization
    Opt [label="ILP Optimizer\n(PuLP)", shape=box3d, fillcolor="#f8d7da"];
    
    // Streamlit
    subgraph cluster_streamlit {
        label="Streamlit Dashboard";
        style=filled;
        color="#d1ecf1";
        
        ST1 [label="1_Predictions"];
        ST2 [label="2_Team_Selector"];
        ST3 [label="3_Match_Preview"];
        ST4 [label="4_Transfers"];
        ST5 [label="5_Captain"];
    }
    
    // Edges
    P1 -> B1;
    P1 -> B2;
    P1 -> B3;
    P2 -> B4;
    P3 -> B5;
    P3 -> B6;
    
    B1 -> S1;
    B2 -> S2;
    B4 -> S3;
    B6 -> S4;
    
    S1 -> Features;
    S2 -> Features;
    S3 -> Features;
    S4 -> Features;
    
    Features -> G1;
    
    G1 -> ML1;
    G1 -> ML2;
    ML1 -> G2;
    ML2 -> G2;
    ML3 -> G2;
    
    G2 -> Opt;
    Opt -> G3;
    
    G2 -> ST1;
    G2 -> ST4;
    G2 -> ST5;
    G3 -> ST2;
}
