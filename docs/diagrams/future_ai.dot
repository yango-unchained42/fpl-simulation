digraph FutureAI {
    rankdir=LR;
    node [shape=box, style="rounded,filled", fontname="Helvetica"];

    // Current system
    A [label="Data", shape=ellipse, fillcolor="#e8f4f8"];
    B [label="ML Models", fillcolor="#f8d7da"];
    C [label="Optimizer", fillcolor="#fcefd4"];

    // Future AI layer
    D [label="News API", shape=ellipse, fillcolor="#e8f4f8"];
    E [label="Sentiment Analysis", fillcolor="#cce5ff"];
    F [label="LLM Generator", fillcolor="#cce5ff"];
    G [label="User Insights", fillcolor="#d4edda"];

    // Edges
    A -> B;
    B -> C;
    B -> D;
    D -> E;
    E -> F;
    F -> G;
    C -> D;
}
